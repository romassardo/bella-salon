# Salón Bella · variables de entorno
# Copiar a .env.local y completar valores reales (NUNCA commitear .env.local).

# ──── Supabase (públicas, expuestas al navegador) ────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública del front (usada en links absolutos del email/calendario).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──── Supabase (server only, nunca commitear) ────
# Se usa para el panel /admin y endpoints autenticados.
SUPABASE_SERVICE_ROLE_KEY=

# ──── n8n webhook (orquestador externo) ────
# n8n maneja: chat IA, persistencia de citas, mails de confirmación, Telegram a la dueña, recordatorios.
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook
N8N_WEBHOOK_SECRET=change_me_to_32_random_bytes

# OpenAI · Telegram · Gmail se configuran como credentials DENTRO de n8n, no como env vars de Next.js.
